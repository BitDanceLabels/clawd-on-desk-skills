{
  "name": "clawd-on-desk",
  "version": "0.8.2",
  "description": "A desktop pet that reacts to your Claude Code sessions in real-time.",
  "main": "src/main.js",
  "scripts": {
    "start": "node launch.js",
    "dev": "cross-env CLAWD_DEVTOOLS=1 ELECTRON_ENABLE_LOGGING=1 node launch.js",
    "dev:quiet": "cross-env CLAWD_DEVTOOLS=0 node launch.js",
    "build:renderer": "node scripts/build-renderer-bundles.js",
    "build": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:all": "npm run build:renderer && electron-builder --win --mac --linux",
    "setup:live2d": "node scripts/setup-live2d.js",
    "setup:demo-models": "node scripts/setup-demo-models.js",
    "setup:all": "node scripts/setup-live2d.js --yes && node scripts/setup-demo-models.js --yes",
    "test": "node --test test/*.test.js",
    "install:gemini-hooks": "node hooks/gemini-install.js",
    "install:cursor-hooks": "node hooks/cursor-install.js"
  },
  "keywords": [
    "clawd",
    "desktop-pet",
    "electron",
    "claude-code"
  ],
  "author": "rullerzhou-afk",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.clawd.on-desk",
    "productName": "Clawd on Desk",
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.entertainment",
      "extendInfo": {
        "LSUIElement": true,
        "NSCameraUsageDescription": "Bumbee Chat uses the camera when you choose to attach a snapshot to a message.",
        "NSMicrophoneUsageDescription": "Bumbee Chat uses the microphone when you turn on voice input.",
        "NSSpeechRecognitionUsageDescription": "Bumbee Chat uses speech recognition when you turn on voice input."
      }
    },
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Clawd-on-Desk-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "rullerzhou-afk <rullerzhou-afk@users.noreply.github.com>",
      "icon": "assets/icons",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "files": [
      "src/**/*",
      "assets/svg/**/*",
      "assets/tray-icon*.png",
      "assets/live2d/**/*",
      "assets/vrm/**/*",
      "hooks/**/*",
      "extensions/**/*",
      "agents/**/*"
    ],
    "asarUnpack": [
      "hooks/**/*",
      "extensions/**/*",
      "assets/live2d/**/*",
      "assets/vrm/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "BitDanceLabels",
        "repo": "clawd-on-desk-skills"
      }
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.2",
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.2",
    "pixi-live2d-display-lipsyncpatch": "^0.5.0-ls-8",
    "pixi.js": "^7.4.3",
    "three": "^0.184.0"
  }
}
